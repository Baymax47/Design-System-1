{
  "name": "project-startup-1",
  "version": "1.0.0",
  "description": "A ready-to-build Node.js + Express project with OpenRouter AI support.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "ds:build": "style-dictionary build --config design-system/sd.config.js",
    "ds:watch": "style-dictionary build --config design-system/sd.config.js --watch",
    "ds:figma": "node design-system/scripts/figma-export.js",
    "ds:dev": "concurrently \"npm run dev\" \"npm run ds:watch\"",
    "build:netlify": "npm run ds:build && node node-copy-script.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "style-dictionary": "^3.9.2"
  }
}
